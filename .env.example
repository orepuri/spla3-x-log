APP_PORT=5173

POSTGRES_DB=spla
POSTGRES_USER=spla
POSTGRES_PASSWORD=change_me_to_a_long_random_password

# Backup container settings. BACKUP_SCHEDULE uses cron syntax in TZ.
TZ=Asia/Tokyo
BACKUP_SCHEDULE="0 6 * * *"
BACKUP_NAME_PREFIX=spla3-x-log

# Cloudflare R2 settings. R2_ENDPOINT is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=splaxlog
R2_PREFIX=backups
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
