FROM postgres:17-alpine

ARG SUPERCRONIC_VERSION=v0.2.34
ARG TARGETOS=linux
ARG TARGETARCH=amd64

RUN apk add --no-cache ca-certificates curl gzip rclone tzdata \
  && curl -fsSL "https://github.com/aptible/supercronic/releases/download/${SUPERCRONIC_VERSION}/supercronic-${TARGETOS}-${TARGETARCH}" -o /usr/local/bin/supercronic \
  && chmod +x /usr/local/bin/supercronic

COPY scripts/backup-postgres-to-r2.sh /usr/local/bin/backup-postgres-to-r2.sh
COPY scripts/start-backup-scheduler.sh /usr/local/bin/start-backup-scheduler.sh

RUN chmod +x /usr/local/bin/backup-postgres-to-r2.sh /usr/local/bin/start-backup-scheduler.sh

ENTRYPOINT ["start-backup-scheduler.sh"]
